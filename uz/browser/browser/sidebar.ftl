## Labels for sidebar context menu items

sidebar-context-menu-customize-sidebar =
    .label = Yon panelni sozlash

## Labels for sidebar menu items.

sidebar-menu-customize-label =
    .label = Yon panelni sozlash

## Tooltips for sidebar menu items.

# The tooltip to show over the history icon, when history is not currently showing.
# Variables:
#   $shortcut (String) - The OS specific keyboard shortcut.
sidebar-menu-open-history-tooltip = Tarixni ochish ({ $shortcut })
# The tooltip to show over the bookmarks icon, when bookmarks is not currently showing.
# Variables:
#   $shortcut (String) - The OS specific keyboard shortcut.
sidebar-menu-open-bookmarks-tooltip = Xatchoʻplarni ochish ({ $shortcut })

## Headings for sidebar menu panels.

sidebar-menu-customize-header =
    .heading = Yon panelni sozlash

## Titles for sidebar menu panels.

sidebar-customize-title = Yon panelni sozlash

## Context for closing synced tabs when hovering over the items

show-sidebars =
    .tooltiptext = Yon panellarni ko‘rsatish
    .label = Yon panellar

## Tooltips for the sidebar toolbar widget.

# Variables:
#   $shortcut (String) - The OS specific keyboard shortcut.
sidebar-widget-expand-sidebar2 =
    .tooltiptext = Yon panelni yoyish ({ $shortcut })
    .label = Yon panel
# Variables:
#   $shortcut (String) - The OS specific keyboard shortcut.
sidebar-widget-collapse-sidebar2 =
    .tooltiptext = Yon panelni yigʻish ({ $shortcut })
    .label = Yon panel
