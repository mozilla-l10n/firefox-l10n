## Customize Toolbar Buttons

toolbar-overflow-customize-button =
    .label = бһ”бҹ’бһҸбһјбһҡвҖӢбһҡбһ”бһ¶бһҡвҖӢбһ§бһ”бһҖбһҡбһҺбҹҚвҖӢбһҸбһ¶бһҳвҖӢбһ”бҹҶбһҺбһ„...
    .accesskey = C
toolbar-button-email-link =
    .label = бһҸбҹҶбһҺвҖӢбһўбҹҠбһёбһҳбҹӮбһӣ
    .tooltiptext = бһўбҹҠбһёбһҳбҹӮбһӣвҖӢбһ—бҹ’бһҮбһ¶бһ”бҹӢвҖӢбһ‘бҹ…вҖӢбһ‘бҹҶбһ–бҹҗбһҡвҖӢбһ“бҹҒбҹҮ
toolbar-button-logins =
    .label = бһ–бһ¶бһҖбҹ’бһҷвҖӢбһҹбһҳбҹ’бһ„бһ¶бһҸбҹӢ
    .tooltiptext = бһҳбһҫбһӣ бһ“бһ·бһ„бһӮбҹ’бһҡбһ”бҹӢбһӮбҹ’бһҡбһ„бһ–бһ¶бһҖбҹ’бһҷбһҹбһҳбҹ’бһ„бһ¶бһҸбҹӢбһҡбһ”бһҹбҹӢбһўбҹ’бһ“бһҖбһҠбҹӮбһӣбһ”бһ¶бһ“бһҡбһҖбҹ’бһҹбһ¶бһ‘бһ»бһҖ
# Variables:
#  $shortcut (String): keyboard shortcut to save a copy of the page
toolbar-button-save-page =
    .label = бһҡбһҖбҹ’бһҹбһ¶бһ‘бһ»бһҖвҖӢбһ‘бҹҶбһ–бҹҗбһҡ
    .tooltiptext = бһҡбһҖбҹ’бһҹбһ¶бһ‘бһ»бһҖвҖӢбһ‘бҹҶбһ–бҹҗбһҡвҖӢбһ“бҹҒбҹҮ ({ $shortcut })
# Variables:
#  $shortcut (String): keyboard shortcut to open a local file
toolbar-button-open-file =
    .label = бһ”бһҫбһҖвҖӢбһҜбһҖбһҹбһ¶бһҡ
    .tooltiptext = бһ”бһҫбһҖвҖӢбһҜбһҖбһҹбһ¶бһҡ ({ $shortcut })
toolbar-button-synced-tabs =
    .label = бһ•бҹ’бһ‘бһ¶бҹҶбһ„вҖӢбһҠбҹӮбһӣвҖӢбһ”бһ¶бһ“вҖӢбһ’бҹ’бһңбһҫвҖӢбһҹбһҳбһҖбһ¶бһӣбһҖбһҳбҹ’бһҳ
    .tooltiptext = бһ”бһ„бҹ’бһ бһ¶бһүвҖӢбһ•бҹ’бһ‘бһ¶бҹҶбһ„вҖӢбһ–бһёвҖӢбһ§бһ”бһҖбһҡбһҺбҹҚвҖӢбһҠбһ‘бҹғвҖӢбһ‘бҹҖбһҸ
# Variables
# $shortcut (string) - Keyboard shortcut to open a new private browsing window
toolbar-button-new-private-window =
    .label = бһ”бһ„бҹ’бһўбһҪбһ…вҖӢбһҜбһҖбһҮбһ“вҖӢбһҗбҹ’бһҳбһё
    .tooltiptext = бһ”бһҫбһҖвҖӢбһ”бһ„бҹ’бһўбһҪбһ…вҖӢбһҖбһ¶бһҡвҖӢбһҡбһ»бһҖбһҡбһҖвҖӢбһҜбһҖбһҮбһ“вҖӢбһҗбҹ’бһҳбһё ({ $shortcut })

