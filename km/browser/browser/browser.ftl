## Pop-up warning

# Variables:
#   $popupCount (Number): the number of pop-ups blocked.
popup-warning-message = { -brand-short-name } бһ”бһ¶бһ“вҖӢбһҖбһ¶бһҡбһ–бһ¶бһҡвҖӢбһ‘бҹҶбһ–бҹҗбһҡвҖӢвҖӢбһ“бҹҒбҹҮбһҳбһ·бһ“вҖӢбһІбҹ’бһҷвҖӢвҖӢвҖӢбһ”бһҫбһҖвҖӢбһ”бһ„бҹ’бһўбһҪбһ…вҖӢбһӣбҹҒбһ…бһЎбһҫбһ„ { $popupCount }бҹ”
popup-warning-button =
    .label =
        { PLATFORM() ->
            [windows] бһҮбһҳбҹ’бһҡбһҫбһҹ
           *[other] бһ…бҹҶбһҺбһјбһӣбһ…бһ·бһҸбҹ’бһҸ
        }
    .accesskey =
        { PLATFORM() ->
            [windows] O
           *[other] P
        }
# Variables:
#   $popupURI (String): the URI for the pop-up window
popup-show-popup-menuitem =
