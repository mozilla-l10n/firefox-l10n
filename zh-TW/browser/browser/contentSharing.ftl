## Variables
##   $count (number) - The number of tabs

content-sharing-modal-more-tabs = +{ $count } 個
content-sharing-tabs-title = { $count } 個分頁
content-sharing-modal-view-page =
    .label = 檢視頁面
content-sharing-modal-copy-link =
    .label = 複製鏈結
content-sharing-modal-link-copied =
    .label = 已複製鏈結
content-sharing-modal-sign-in =
    .label = 登入即可分享鏈結
content-sharing-modal-title = 從任何瀏覽器分享這些鏈結
content-sharing-modal-description = 為這些鏈結建立可簡單分享的公開頁面。頁面建立後就無法再編輯或刪除，並於 7 天後失效。
content-sharing-modal-policy = 若分享，代表您同意我們的<a data-l10n-name="aup-link">可接受的使用政策</a>
# This is a warning to the user when they try to share more than the maximum
# number of links and that the first N links will be shared.
# The current max is 30.
content-sharing-modal-too-many-links = 最多只會包含 { $count } 個鏈結
content-sharing-modal-generic-error =
    .heading = 有些東西不對勁
    .message = 請稍後再試。
