## Variables
##   $count (number) - The number of tabs

content-sharing-modal-more-tabs = +{ $count } thẻ khác
content-sharing-tabs-title = { $count } thẻ
content-sharing-modal-view-page-2 =
    .label = Xem trước trang
content-sharing-modal-copy-link =
    .label = Sao chép liên kết
content-sharing-modal-generating-page =
    .label = Đang tạo trang…
content-sharing-modal-link-copied =
    .label = Liên kết đã được sao chép
content-sharing-modal-sign-in-2 =
    .label = Đăng nhập để chia sẻ
content-sharing-modal-title-2 = Chia sẻ các trang này với mọi người
content-sharing-modal-title-signed-in = Liên kết của bạn đã sẵn sàng để chia sẻ
content-sharing-modal-description-2 = Đăng nhập để dễ dàng chia sẻ trang với các liên kết. Nó không thể chỉnh sửa hoặc xoá và sẽ hết hạn sau 7 ngày.
content-sharing-modal-description-signed-in = Chúng tôi đã chia sẻ trang với các liên kết của bạn. Nó không thể chỉnh sửa hoặc xoá và sẽ hết hạn sau 7 ngày.
content-sharing-modal-policy = Bằng cách chia sẻ, bạn đồng ý với <a data-l10n-name="aup-link">Chính sách sử dụng chấp nhận được</a> của chúng tôi
# This is a warning to the user when they try to share more than the maximum
# number of links and that the first N links will be shared.
# The current max is 30.
content-sharing-modal-too-many-links-2 = Tối đa { $count } liên kết được thêm vào
content-sharing-modal-no-shareable-links =
    .heading = Không bao gồm liên kết được chia sẻ
    .message = Chỉ được phép chia sẻ các liên kết đến nội dung web.
# Variables:
#   $count (Number) - The maximum number of pages a user can share at one time
content-sharing-modal-too-many-pages =
    .heading = Bạn đã chia sẻ { $count } trang
    .message = Hãy thử lại sau khi một trong các trang của bạn hết hạn.
content-sharing-modal-some-invalid-links = Một số liên kết không thể chia sẻ.
content-sharing-modal-generic-error-2 =
    .heading = Có gì đó không ổn
    .message = Chúng tôi không thể tạo trang chia sẻ cho bạn lúc này. Vui lòng thử lại sau.
