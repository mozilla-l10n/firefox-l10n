## Names of the default containers in Firefox.
## See https://support.mozilla.org/kb/how-use-firefox-containers

user-context-personal =
    .label = ವೈಯಕ್ತಿಕ
    .accesskey = P
user-context-work =
    .label = ಕೆಲಸ
    .accesskey = W
user-context-banking =
    .label = ಬ್ಯಾಂಕಿಂಗ್
    .accesskey = B
user-context-shopping =
    .label = ಶಾಪಿಂಗ್
    .accesskey = S

