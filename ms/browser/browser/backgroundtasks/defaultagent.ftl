default-browser-agent-task-description = Tugas Ejen Pelayar Lalai menyemak apabila lalai bertukar daripada { -brand-short-name } ke pelayar lain. Jika perubahan berlaku dalam keadaan mencurigakan, ia akan meminta pengguna menukar kembali ke { -brand-short-name } tidak lebih daripada dua kali. Tugas ini dipasang secara automatik oleh { -brand-short-name }, dan dipasang semula apabila { -brand-short-name } dikemas kini. Untuk melumpuhkan tugas ini, kemas kini keutamaan “default-browser-agent.enabled” pada halaman about:config atau tetapan polisi perusahaan { -brand-short-name } “DisableDefaultBrowserAgent”.
default-browser-notification-privacy-header-text = Kekal dengan { -brand-short-name }?
default-browser-notification-privacy-body-text = Lalai anda telah berubah. Kembali ke { -brand-short-name } untuk privasi dan perlindungan terbina dalam.
default-browser-notification-header-text = Teruskan menggunakan { -brand-short-name }?
default-browser-notification-body-text = Pelayar lalai anda baru-baru ini telah diubah. Ketik untuk pulihkan { -brand-short-name } sebagai lalai.
default-browser-notification-yes-button-text = Ya
default-browser-notification-privacy-no-button-text = Tidak, terima kasih
default-browser-notification-no-button-text = Tidak
