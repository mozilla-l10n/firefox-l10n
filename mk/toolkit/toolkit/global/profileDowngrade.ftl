profiledowngrade-window2 =
    .title = Стартувавте постара верзија на { -brand-product-name }
    .style = min-width: 490px;
profiledowngrade-window-create =
    .label = Креирај нов профил
profiledowngrade-sync = Користењето на постара верзија на { -brand-product-name } може да ги оштети обележувачите и историјата на прелистување што веќе се зачувани на постоечки профил на { -brand-product-name }. За да ги заштитите вашите информации, креирајте нов профил за оваа инсталација на { -brand-short-name }. Секогаш можете да се најавите со { -fxaccount-brand-name } за да ги синхронизирате вашите обележувачи и историјата на прелистување помеѓу профилите.
profiledowngrade-sync2 = Користењето на постара верзија на { -brand-product-name } може да ги оштети обележувачите и историјата на прелистување што веќе се зачувани на постоечки профил на { -brand-product-name }. За да ги заштитите вашите информации, креирајте нов профил за оваа инсталација на { -brand-short-name }. Секогаш можете да се најавите со сметка за да ги синхронизирате вашите обележувачи и историјата на прелистување помеѓу профилите.
profiledowngrade-nosync = Користењето на постара верзија на { -brand-product-name } може да ги оштети обележувачите и историјата на прелистување што веќе се зачувани на постоечки профил на { -brand-product-name }. За да ги заштитите вашите информации, креирајте нов профил за оваа инсталација на { -brand-short-name }.
profiledowngrade-quit =
    .label =
        { PLATFORM() ->
            [windows] Излези
           *[other] Излези
        }
