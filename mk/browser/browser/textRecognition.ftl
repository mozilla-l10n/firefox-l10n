## Text recognition works through a modal that presents the text that is found
## in an image, and copies the results to the clipboard.

text-recognition-modal-searching-title = Се пребарува слика за текст…
text-recognition-modal-results-title = Текстот е копиран од сликата
text-recognition-modal-no-results-title = За жал, не можевме да извлечеме текст. Обидете се со друга слика. <a data-l10n-name="error-link">Дознајте повеќе</a>.
text-recognition-modal-close-button = Затвори
# The title of the the modal is only available to screen readers.
text-recognition-modal-accessible-modal-title = Резултати за извлекување текст
