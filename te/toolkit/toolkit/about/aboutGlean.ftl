### "FOG", "Glean", and "Glean SDK" should remain in English.

# This message refers to the category in which a given metric is recorded.
about-glean-metrics-table-header-category = వర్గం
# This message refers to the name of a given metric.
about-glean-metrics-table-header-name = పేరు
# This message refers to a given metric's metric type.
about-glean-metrics-table-header-type = రకం
# This message refers to the underlying value of a given metric.
about-glean-metrics-table-header-value = విలువ
# This message refers to the UI action buttons for a given metric.
about-glean-metrics-table-header-actions = చర్యలు
about-glean-metrics-table-settings-button = అమరికలు
# This is a heading that is immediately followed by an example data visualization
about-glean-metrics-table-settings-visualization-example = ఉదాహరణ
about-glean-metrics-table-settings-timelines-height = ఎత్తు
about-glean-metrics-table-settings-timelines-width = వెడల్పు
# Label displayed near an input field that can be used to filter metrics
about-glean-label-for-filter-metrics = వడపోత
