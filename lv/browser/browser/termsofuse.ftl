## Existing User Terms of Use InfoBar

#  Full infobar message, with inline links to the Terms of Use and Privacy Notice that will be added at runtime.
existing-user-tou-message = <strong>Atjauninājums</strong> Esam ieviesuši { -brand-short-name } <a data-l10n-name="terms-of-use-link">Lietošanas noteikumus</a> un atjauninājuši mūsu <a data-l10n-name="privacy-notice-link">Paziņojumu par konfidencialitāti</a>. Lūdzu, veltiet brīdi, lai tos pārskatītu un pieņemtu.
# Infobar message for when the Privacy Notice is updated.
existing-user-privacy-notice-update-message = Esam atjauninājuši savu <a data-l10n-name="privacy-notice-link">Paziņojumu par konfidencialitāti</a>, lai atspoguļotu jaunāko { -brand-short-name } funkcionalitāti.
# Text for secondary button linking to FAQ page
existing-user-tou-learn-more = Uzzināt vairāk
# Text for primary button
existing-user-tou-accept = Piekrist

## Existing User Terms of Use Spotlight

# Full Spotlight body message, with inline links to the Terms of Use, Privacy Notice, and Learn More FAQ that will be added at runtime.
tou-existing-user-spotlight-body = Esam ieviesuši <a data-l10n-name="terms-of-use">Lietošanas noteikumus</a> un atjauninājuši mūsu <a data-l10n-name="privacy-notice">Paziņojumu par konfidencialitāti</a>.<br><br> Lūdzu, veltiet brīdi, lai tos pārskatītu un pieņemtu. <a data-l10n-name="learn-more">Uzzināt vairāk</a>.
tou-existing-user-spotlight-remind-me-later = Atgādināt vēlāk
