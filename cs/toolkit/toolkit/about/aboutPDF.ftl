about-pdf-title =
    { -brand-short-name.case-status ->
        [with-cases] PDF editor ve { -brand-short-name(case: "loc") }
       *[no-cases] PDF editor v aplikaci { -brand-short-name }
    }
about-pdf-header = { -brand-short-name } PDF
about-pdf-tagline = Bezplatný nástroj pro čtení, slučování, podepisování, přidávání komentářů a další činnosti — s integrovanými prvky pro ochranu soukromí
about-pdf-dropzone =
    .title = Sem pro začátek přetáhněte PDF nebo stiskněte Enter
about-pdf-dropzone-hint = Pro začátek sem přetáhněte PDF
about-pdf-dropzone-privacy-hint = Soubory zůstávají v soukromí na vašem zařízení.
about-pdf-dropzone-invalid-file = Tento soubor není podporován. Pro pokračování vyberte PDF.
about-pdf-dropzone-error-generic = Nahrávání se nezdařilo. Zkuste to znovu později.
about-pdf-browse-files =
    .label = Procházet soubory
about-pdf-promo =
    .heading = Nastavte si aplikaci { -brand-short-name } jako svůj oblíbený editor PDF
    .message = Otevírejte soubory PDF v aplikaci { -brand-short-name } a provádějte základní úkony na jednom místě – od zvýrazňování a podepisování až po slučování souborů a vkládání komentářů.
about-pdf-set-default =
    .label = Nastavit jako výchozí
about-pdf-dismiss =
    .label = Zavřít
