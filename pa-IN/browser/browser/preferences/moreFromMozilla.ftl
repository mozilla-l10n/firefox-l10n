more-from-moz-mozilla-vpn-title = { -mozilla-vpn-brand-name }
more-from-moz-mozilla-vpn-description = ਬਰਾਊਜ਼ ਕਰਨ ਵਾਲੇ ਅਣਪਛਾਤੇ ਰਹਿਣ ਦੀ ਪਰਤ ਜੋੜਨ ਅਤੇ ਸੁਰੱਖਿਆ ਲੈਣ ਬਾਰੇ ਜਾਣਕਾਰੀ ਲਵੋ।
