## These strings are used in the about:preferences moreFromMozilla page

more-from-moz-title = { -vendor-short-name } ਵਲੋਂ ਹੋਰ
more-from-moz-page-header =
    .heading = { -vendor-short-name } ਵਲੋਂ ਹੋਰ
