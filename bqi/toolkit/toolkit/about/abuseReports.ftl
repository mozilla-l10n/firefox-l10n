# Localized string used as the dialog window title.
# "Report" is a noun in this case, "Report for AddonName".
#
# Variables:
#   $addon-name (string) - Name of the add-on being reported
abuse-report-dialog-title = گوزارش سی { $addon-name }
abuse-report-title-extension = گوزارش ای وردنی و { -vendor-short-name }
# Variables:
#   $author-name (string) - Name of the add-on author
abuse-report-addon-authored-by = و دست <a data-l10n-name="author-name">{ $author-name }</a>

## Panel buttons.

abuse-report-cancel-button = لقو

## Message bars descriptions.
##
## Variables:
##   $addon-name (string) - Name of the add-on

abuse-report-messagebar-aborted = گوزارش سی <span data-l10n-name="addon-name">{ $addon-name }</span> لقو وابیڌ.

## Message bars actions.

abuse-report-messagebar-action-cancel = لقو
