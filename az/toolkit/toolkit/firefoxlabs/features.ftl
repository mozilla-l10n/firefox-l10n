# Tab Notes
experimental-features-tab-notes =
    .label = Vərəq qeydləri
experimental-features-tab-notes-description = Vərəq qeydləri brauzer vərəqlərinə yapışqan qeydlər əlavə etməyə imkan verən eksperimental özəllikdir. Kontekst, xatırlatmalar və ya növbəti addımlar barədə qeydlər yazın ki, sonradan geri qayıdanda həmin vərəqi niyə açdığınızı xatırlaya biləsiniz. Bu özəlliyi təkmilləşdirməyə davam etdiyimiz üçün rəylərinizi bizimlə bölüşməyinizi istərdik. <a data-l10n-name="connect">Rəy bildirin</a>”
