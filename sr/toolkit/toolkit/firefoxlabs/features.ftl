# New Tab Sections with follow and block
experimental-features-newtab-sections-follow-block =
    .label = Одељци тема и праћење/блокирање за приче у новом језичку
experimental-features-newtab-sections-follow-block-description = Организујте приче на својој страници новог језичка у одељке тема (спорт, храна, забава и још много тога) за структурираније искуство које је лакше за преглед. Користите наше нове контроле за праћење и блокирање да бисте прилагодили садржај који видите. <a data-l10n-name="connect">Пошаљите повратне информације</a>
# Firefox Web Apps
experimental-features-fx-web-apps =
    .label = Додајте сајтове на своју траку задатака
# “Add tab to taskbar” is found in the tooltip text of `-taskbar-tab-urlbar-button-open`.
experimental-features-fx-web-apps-description = Отворите сајтове које често посећујете као веб апликацију са своје траке задатака. Потражите икону „Додај језичак на траку задатака” десно од адресне траке да бисте покренули тај сајт у поједностављеном прозору са свим заштитама које пружа { -brand-product-name }. <a data-l10n-name="connect">Пошаљите повратне информације</a>

## New Tab Productivity Widgets

# Lists Widget
experimental-features-newtab-widget-lists =
    .label = Спискови на { -firefox-home-brand-name }
experimental-features-newtab-widget-lists-description = Нека вам списак обавеза буде на уму када отворите нови језичак. Од спискова за паковање до спискова за куповину, правите своје планове у { -brand-product-name } прегледачу. <a data-l10n-name="connect">Пошаљите повратне информације</a>
# Timer Widget
experimental-features-newtab-widget-timer =
    .label = Одбројавач на { -firefox-home-brand-name } почетној страници
experimental-features-newtab-widget-timer-description = Поставите одбројавач који ће вас држати фокусираним, подстаћи вас да останете на путу или вас подсетити да се освежите. <a data-l10n-name="connect">Пошаљите повратне информације</a>
# Lists and Timer Widget (Combined)
experimental-features-newtab-widget-lists-and-timer =
    .label = Спискови и одбројавач на { -firefox-home-brand-name } почетној страници
experimental-features-newtab-widget-lists-and-timer-description = Нека вам списак обавеза буде на уму када отворите нови језичак. Од спискова за паковање до спискова за куповину, правите своје планове у { -brand-product-name } прегледачу. Поставите одбројавач који ће вас држати фокусираним, подстаћи вас да останете на путу или вас подсетити да се освежите. <a data-l10n-name="connect">Пошаљите повратне информације</a>
# Semantic History Search
experimental-features-semantic-history-search =
    .label = Семантичка претрага историјата
experimental-features-semantic-history-search-description = Користите локални модел машинског учења за предлагање уноса из историјата који су повезани са вашим претрагама на основу разумевања природног језика у { -brand-product-name } адресној траци. <a data-l10n-name="connect">Пошаљите повратне информације</a>
# Tab Notes
experimental-features-tab-notes =
    .label = Белешке језичака
experimental-features-tab-notes-description = Белешке језичака су експериментална функција која вам омогућава да додате лепљиве белешке у језичке вашег прегледача. Запишите контекст, подсетнике или следеће кораке како бисте могли да се вратите и сетите се зашто сте их отворили. Волели бисмо ваше повратне информације док настављамо да побољшавамо ову функцију. <a data-l10n-name="connect">Пошаљите повратне информације</a>
